---
import "../styles/globals.css";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";

interface Alternate {
  hreflang: string;
  href: string;
}

interface Props {
  title: string;
  description?: string;
  canonical?: string;
  ogImage?: string;
  ogImageAlt?: string;
  ogType?: "website" | "article";
  current?: string;
  showNav?: boolean;
  showFooter?: boolean;
  lang?: string;
  alternates?: Alternate[];
  markdownAlternate?: string;
  articlePublishedTime?: string;
  articleAuthor?: string;
}

const {
  title,
  description = "SVRNOS — Sovereign operating systems for AI governance.",
  canonical,
  ogImage,
  ogImageAlt,
  ogType = "website",
  current,
  showNav = true,
  showFooter = true,
  lang = "en",
  alternates,
  markdownAlternate,
  articlePublishedTime,
  articleAuthor,
} = Astro.props;

const markdownAlternateURL = markdownAlternate
  ? new URL(markdownAlternate, Astro.site).toString()
  : undefined;

const canonicalURL = canonical
  ? new URL(canonical, Astro.site).toString()
  : new URL(Astro.url.pathname, Astro.site).toString();

const resolvedAlternates = alternates?.map((a) => ({
  hreflang: a.hreflang,
  href: new URL(a.href, Astro.site).toString(),
}));
---
<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    {resolvedAlternates?.map((a) => (
      <link rel="alternate" hreflang={a.hreflang} href={a.href} />
    ))}
    {markdownAlternateURL && (
      <link rel="alternate" type="text/markdown" href={markdownAlternateURL} title="Markdown version (for AI assistants)" />
    )}
    <meta property="og:site_name" content="SVRNOS" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:type" content={ogType} />
    {ogImage && <meta property="og:image" content={ogImage} />}
    {ogImage && ogImageAlt && <meta property="og:image:alt" content={ogImageAlt} />}
    {ogType === "article" && articlePublishedTime && (
      <meta property="article:published_time" content={articlePublishedTime} />
    )}
    {ogType === "article" && articleAuthor && (
      <meta property="article:author" content={articleAuthor} />
    )}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    {ogImage && <meta name="twitter:image" content={ogImage} />}
    {ogImage && ogImageAlt && <meta name="twitter:image:alt" content={ogImageAlt} />}
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Instrument+Serif:ital@0;1&family=Geist+Mono:wght@400;500&display=swap"
    />
    <slot name="head" />
  </head>
  <body>
    {showNav && <Nav current={current} />}
    <slot />
    {showFooter && <Footer />}
  </body>
</html>
