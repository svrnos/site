---
import "../styles/globals.css";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";

interface Alternate {
  hreflang: string;
  href: string;
}

interface ScholarCitation {
  title: string;
  author: string;
  publicationDate: string;
  onlineDate?: string;
  publisher?: string;
  abstract?: string;
  keywords?: string;
}

interface Props {
  title: string;
  description?: string;
  canonical?: string;
  ogImage?: string;
  ogImageAlt?: string;
  ogType?: "website" | "article";
  current?: string;
  showNav?: boolean;
  showFooter?: boolean;
  lang?: string;
  alternates?: Alternate[];
  markdownAlternate?: string;
  articlePublishedTime?: string;
  articleAuthor?: string;
  citation?: ScholarCitation;
}

const {
  title,
  description = "SVRNOS — Sovereign operating systems for AI governance.",
  canonical,
  ogImage,
  ogImageAlt,
  ogType = "website",
  current,
  showNav = true,
  showFooter = true,
  lang = "en",
  alternates,
  markdownAlternate,
  articlePublishedTime,
  articleAuthor,
  citation,
} = Astro.props;

const markdownAlternateURL = markdownAlternate
  ? new URL(markdownAlternate, Astro.site).toString()
  : undefined;

const canonicalURL = canonical
  ? new URL(canonical, Astro.site).toString()
  : new URL(Astro.url.pathname, Astro.site).toString();

const resolvedAlternates = alternates?.map((a) => ({
  hreflang: a.hreflang,
  href: new URL(a.href, Astro.site).toString(),
}));
---
<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    {resolvedAlternates?.map((a) => (
      <link rel="alternate" hreflang={a.hreflang} href={a.href} />
    ))}
    {markdownAlternateURL && (
      <link rel="alternate" type="text/markdown" href={markdownAlternateURL} title="Markdown version (for AI assistants)" />
    )}
    {citation && (
      <>
        <meta name="citation_title" content={citation.title} />
        <meta name="citation_author" content={citation.author} />
        <meta name="citation_publication_date" content={citation.publicationDate} />
        {citation.onlineDate && (
          <meta name="citation_online_date" content={citation.onlineDate} />
        )}
        {citation.publisher && (
          <meta name="citation_publisher" content={citation.publisher} />
        )}
        {citation.abstract && (
          <meta name="citation_abstract" content={citation.abstract} />
        )}
        {citation.keywords && (
          <meta name="citation_keywords" content={citation.keywords} />
        )}
      </>
    )}
    <meta property="og:site_name" content="SVRNOS" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:type" content={ogType} />
    {ogImage && <meta property="og:image" content={ogImage} />}
    {ogImage && ogImageAlt && <meta property="og:image:alt" content={ogImageAlt} />}
    {ogType === "article" && articlePublishedTime && (
      <meta property="article:published_time" content={articlePublishedTime} />
    )}
    {ogType === "article" && articleAuthor && (
      <meta property="article:author" content={articleAuthor} />
    )}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    {ogImage && <meta name="twitter:image" content={ogImage} />}
    {ogImage && ogImageAlt && <meta name="twitter:image:alt" content={ogImageAlt} />}
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Instrument+Serif:ital@0;1&family=Geist+Mono:wght@400;500&display=swap"
    />
    <slot name="head" />
    {import.meta.env.PUBLIC_COOKIEBOT_ID && (
      <script
        id="Cookiebot"
        src="https://consent.cookiebot.com/uc.js"
        data-cbid={import.meta.env.PUBLIC_COOKIEBOT_ID}
        data-blockingmode="auto"
        type="text/javascript"
        async
      ></script>
    )}
    <script defer src="/_vercel/insights/script.js"></script>
    {import.meta.env.PUBLIC_LINKEDIN_PARTNER_ID && (
      <Fragment>
        <script is:inline define:vars={{ partnerId: import.meta.env.PUBLIC_LINKEDIN_PARTNER_ID }}>
          _linkedin_partner_id = partnerId;
          window._linkedin_data_partner_ids = window._linkedin_data_partner_ids || [];
          window._linkedin_data_partner_ids.push(_linkedin_partner_id);
        </script>
        <script is:inline>
          (function(l){if(!l){window.lintrk=function(a,b){window.lintrk.q.push([a,b])};window.lintrk.q=[]}var s=document.getElementsByTagName("script")[0];var b=document.createElement("script");b.type="text/javascript";b.async=true;b.src="https://snap.licdn.com/li.lms-analytics/insight.min.js";s.parentNode.insertBefore(b,s);})(window.lintrk);
        </script>
        <noscript>
          <img height="1" width="1" style="display:none;" alt="" src={`https://px.ads.linkedin.com/collect/?pid=${import.meta.env.PUBLIC_LINKEDIN_PARTNER_ID}&fmt=gif`} />
        </noscript>
      </Fragment>
    )}
    {import.meta.env.PUBLIC_GA4_MEASUREMENT_ID && (
      <Fragment>
        <script is:inline async src={`https://www.googletagmanager.com/gtag/js?id=${import.meta.env.PUBLIC_GA4_MEASUREMENT_ID}`}></script>
        <script is:inline define:vars={{ measurementId: import.meta.env.PUBLIC_GA4_MEASUREMENT_ID }}>
          window.dataLayer = window.dataLayer || [];
          function gtag(){dataLayer.push(arguments);}
          gtag('js', new Date());
          gtag('config', measurementId, { anonymize_ip: true });
        </script>
      </Fragment>
    )}
  </head>
  <body>
    {showNav && <Nav current={current} />}
    <slot />
    {showFooter && <Footer />}
  </body>
</html>
