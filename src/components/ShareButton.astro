---
// Share button widget — preserves the existing pattern from bespoke insight pages.
// Uses the Web Share API when available (mobile, modern browsers), falls back to
// copying the canonical URL to clipboard. Tries to attach the og:image as a file
// when the platform supports image sharing.
---
<div class="share-bar">
  <button
    aria-label="Share article"
    class="share-btn"
    id="shareBtn"
    type="button"
  >
    <svg
      fill="none"
      stroke="currentColor"
      stroke-linecap="round"
      stroke-linejoin="round"
      stroke-width="2"
      viewBox="0 0 24 24"
    >
      <circle cx="18" cy="5" r="3"></circle>
      <circle cx="6" cy="12" r="3"></circle>
      <circle cx="18" cy="19" r="3"></circle>
      <line x1="8.59" x2="15.42" y1="13.51" y2="17.49"></line>
      <line x1="15.41" x2="8.59" y1="6.51" y2="10.49"></line>
    </svg>
    <span>Share</span>
  </button>
</div>

<style>
  .share-bar {
    max-width: 68ch;
    margin: 16px auto 0;
    padding: 0 32px;
  }
  .share-btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 8px 14px;
    background: transparent;
    color: inherit;
    border: 1px solid currentColor;
    border-radius: 999px;
    font: 500 14px/1 var(--svrnos-font-sans);
    cursor: pointer;
    opacity: 0.6;
    transition: opacity 0.15s ease;
  }
  .share-btn:hover {
    opacity: 1;
  }
  .share-btn svg {
    width: 14px;
    height: 14px;
    flex-shrink: 0;
  }
</style>

<script>
  document.getElementById("shareBtn")?.addEventListener("click", async () => {
    const m = (p: string) =>
      document.querySelector(`meta[property="${p}"]`)?.getAttribute("content") ||
      document.querySelector(`meta[name="${p}"]`)?.getAttribute("content") ||
      "";
    const baseShareData: ShareData = {
      title: m("og:title") || document.title,
      text: m("og:description") || "",
      url: window.location.href,
    };
    let shareData = baseShareData;
    try {
      const imgUrl = m("og:image");
      if (imgUrl) {
        const res = await fetch(imgUrl);
        if (res.ok) {
          const blob = await res.blob();
          const file = new File([blob], "share.png", { type: blob.type });
          if (navigator.canShare && navigator.canShare({ files: [file] })) {
            shareData = { ...baseShareData, files: [file] };
          }
        }
      }
    } catch (e) {
      /* fall through */
    }
    if (navigator.share) {
      try {
        await navigator.share(shareData);
      } catch (e) {
        /* user cancelled */
      }
    } else {
      try {
        await navigator.clipboard.writeText(window.location.href);
        alert("Link copied to clipboard");
      } catch (e) {
        alert("Could not copy link");
      }
    }
  });
</script>
