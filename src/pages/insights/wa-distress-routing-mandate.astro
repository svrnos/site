  <p class="article-cat-tag article-cat-tag-governance not-prose">Governance</p>

  <dl class="article-supplement not-prose">
    <div><dt>Published</dt><dd>April 30, 2026</dd></div>
    <div><dt>Author</dt><dd>Sushee Nzeutem, SVRNOS LLC</dd></div>
  </dl>

  <ShareButton />

  <ArticleFigure
    src="/insights/wa-distress-routing-mandate/wa-distress-routing-mandate-title.png"
    alt="Washington Just Made Distress Routing a Legal Requirement - HB 2225, effective January 1, 2027"
    hero
    loading="eager"
